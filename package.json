{
  "name": "moneymate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:local:start": "powershell -ExecutionPolicy Bypass -File ./scripts/prisma-local-db.ps1 start",
    "db:local:status": "powershell -ExecutionPolicy Bypass -File ./scripts/prisma-local-db.ps1 status",
    "db:local:sync-env": "powershell -ExecutionPolicy Bypass -File ./scripts/prisma-local-db.ps1 sync-env",
    "db:local:reset": "powershell -ExecutionPolicy Bypass -File ./scripts/prisma-local-db.ps1 reset",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "worker": "tsx workers/parsing/worker.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.744.0",
    "@aws-sdk/s3-request-presigner": "^3.744.0",
    "@hookform/resolvers": "^4.1.0",
    "@prisma/client": "6.12.0",
    "@tanstack/react-query": "^5.64.0",
    "@tanstack/react-table": "^8.20.5",
    "argon2": "^0.41.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "next": "^15.0.0",
    "pdfjs-dist": "^4.10.38",
    "pg-boss": "^10.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.49",
    "prisma": "6.12.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  }
