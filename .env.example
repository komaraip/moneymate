# Use any regular PostgreSQL database for the most stable local setup.
# If you prefer Prisma local Postgres on Windows, run `npm run db:local:start`
# and the helper will sync the generated prisma+postgres URL into `.env`.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/moneymate"
APP_URL="http://localhost:3000"
SESSION_COOKIE_NAME="moneymate_session"
SESSION_TTL_DAYS="30"
AWS_REGION="ap-southeast-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_S3_ENDPOINT=""
UPLOAD_URL_TTL_SECONDS="900"
PDF_MAX_SIZE_BYTES="10485760"
PG_BOSS_SCHEMA="pbboss"
ARGON2_MEMORY_COST="19456"
ARGON2_TIME_COST="2"
